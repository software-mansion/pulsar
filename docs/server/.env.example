# Pulsar server environment. Copy to .env for local dev; inject these into the
# container at runtime in production.

# --- Required ---------------------------------------------------------------
# Postgres connection string. Required — the server refuses to boot without it.
DATABASE_URL=postgres://user:password@localhost:5432/pulsar
# Set to 1/true/require when the DB needs TLS (managed providers: Neon, RDS…).
# DATABASE_SSL=

# HTTP/WS port (defaults to 8080).
# PORT=8080

# --- Figma OAuth (optional) -------------------------------------------------
# Enables the "read haptics straight from the Figma file" preview path. When
# unset, the OAuth routes return 503 and the plugin falls back to the token/DB
# share path — everything else works unchanged.
#
# Create an OAuth app at https://www.figma.com/developers/apps and register the
# redirect URI below as a callback. The client secret is used server-side only
# (HTTP Basic on the token-exchange/refresh calls) and must never ship to the
# plugin or preview.
# FIGMA_OAUTH_CLIENT_ID=
# FIGMA_OAUTH_CLIENT_SECRET=
# Must EXACTLY match a callback URL registered on the Figma OAuth app, e.g.
# https://pulsar-server.swmansion.com/figma-auth/callback
# FIGMA_OAUTH_REDIRECT_URI=
# Namespace the plugin writes shared plugin data under. Must match SHARED_NS in
# figma/src/main/code.ts. Defaults to "pulsar"; override only if you change both.
# FIGMA_SHARED_NAMESPACE=pulsar
# Informational/forward-compat: the plugin id whose private pluginData we could
# read. The current flow reads *shared* plugin data (plugin_data=shared), so this
# is optional.
# FIGMA_PLUGIN_ID=
