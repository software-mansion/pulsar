{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "setupFiles": ["<rootDir>/tests/setup.ts"],
  "testMatch": ["**/*.test.ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "collectCoverageFrom": ["src/**/*.ts", "!src/server.ts"],
  "coverageDirectory": "coverage",
  "verbose": true,
  "testTimeout": 10000
}
