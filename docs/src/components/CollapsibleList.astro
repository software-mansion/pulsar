---
interface Props {
  items: string[];
  initialItems?: number;
  code?: boolean;
  columns?: number;
}

const { items, initialItems = 5, code = false, columns = 1 } = Astro.props;
const hasMore = items.length > initialItems;
const id = `list-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="collapsible-list">
  <ul style={columns > 1 ? `column-count: ${columns}` : undefined}>
    {items.map((item, i) => (
      <li class={i >= initialItems ? `${id}-extra hidden` : ''}>{code ? <code>{item}</code> : item}</li>
    ))}
  </ul>
  {hasMore && (
    <button
      class="show-more-btn"
      data-target={id}
      data-label-more={`Show ${items.length - initialItems} more`}
      data-label-less="Show less"
    >
      Show {items.length - initialItems} more
    </button>
  )}
</div>

<style>
  .collapsible-list {
    margin-bottom: 1rem;
  }
  .hidden {
    display: none;
  }
  .show-more-btn {
    padding: 0.35rem 0.85rem 0.3rem 0.85rem;
    font-size: 0.85rem;
    font-weight: bold;
    border: 1px solid var(--color-primary);
    border-radius: 4px;
    background: transparent;
    color: var(--color-primary);
    cursor: pointer;
  }
  .show-more-btn:hover {
    background: var(--color-primary-light);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.show-more-btn:not([data-initialized])').forEach((btn) => {
    btn.dataset.initialized = 'true';
    btn.addEventListener('click', () => {
      const id = btn.dataset.target!;
      const extras = document.querySelectorAll<HTMLElement>(`.${id}-extra`);
      const expanded = !extras[0]?.classList.contains('hidden');
      extras.forEach((item) => item.classList.toggle('hidden', expanded));
      btn.textContent = expanded ? btn.dataset.labelMore! : btn.dataset.labelLess!;
    });
  });
</script>
