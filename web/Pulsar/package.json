{
  "name": "pulsar-haptics",
  "version": "0.1.1",
  "description": "A TypeScript library for playing haptics on web devices — works in vanilla JS, React, and any modern framework.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/haptics.cjs",
  "module": "./dist/haptics.es.js",
  "browser": "./dist/haptics.es.js",
  "unpkg": "./dist/haptics.iife.js",
  "jsdelivr": "./dist/haptics.iife.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/haptics.es.js",
      "require": "./dist/haptics.cjs",
      "default": "./dist/haptics.es.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.es.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.es.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "example": "vite --host",
    "build": "vite build && vite build --config vite.react.config.ts && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --declarationDir dist && node scripts/rewrite-dts-extensions.mjs",
    "test": "node --test --experimental-strip-types tests/*.test.js",
    "presets:json": "node --experimental-strip-types scripts/generate-presets.ts",
    "presets:images": "node --experimental-strip-types scripts/generate-images.ts",
    "presets": "npm run presets:json && npm run presets:images",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm install && npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-test-renderer": "^18.3.0",
    "react": "^18.3.0",
    "react-test-renderer": "^18.3.0",
    "typescript": "^5.9.2",
    "vite": "^6.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "haptics",
    "vibration",
    "web",
    "typescript",
    "react",
    "vanilla-js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/software-mansion/pulsar"
  },
  "bugs": {
    "url": "https://github.com/software-mansion/pulsar/issues"
  }
}
