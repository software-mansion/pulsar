{
  "name": "pulsar-figma-plugin",
  "version": "0.1.0",
  "description": "Pulsar haptics for Figma — bind presets to components, hear them in edit & prototype mode, play on a paired phone.",
  "private": true,
  "scripts": {
    "build": "vite build --config vite.main.config.ts && vite build",
    "dev": "concurrently -k \"vite build --watch\" \"vite build --watch --config vite.main.config.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.108.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
